{
  "schemaVersion": 1,
  "id": "org.marginalia.examples.dark-mode",
  "name": "Dark Mode",
  "version": "0.1.5",
  "kind": "theme",
  "execution": "module",
  "summary": "An OS-wide inverted screen theme for Marginalia",
  "author": "Marginalia",
  "license": "MIT",
  "target": {
    "devices": ["xteink-x3", "xteink-x4"],
    "chipFamilies": ["esp32-c3"],
    "minFirmware": "0.1.0",
    "apiLevel": 1,
    "ramClass": "low",
    "requiresPSRAM": false
  },
  "permissions": ["display", "settings"],
  "settings": [
    {
      "id": "invertScreen",
      "label": "Invert screen",
      "type": "boolean",
      "default": true
    },
    {
      "id": "textAntialiasing",
      "label": "Antialiasing",
      "type": "boolean",
      "default": false
    },
    {
      "id": "readerRefresh",
      "label": "Reader cleanup",
      "type": "enum",
      "default": "5-pages",
      "options": ["off", "every-page", "5-pages", "10-pages"]
    }
  ],
  "dependencies": [],
  "entrypoints": {
    "onLoad": "init",
    "onUnload": "shutdown"
  },
  "assets": {
    "icon": "icon.png",
    "preview": "preview.png"
  },
  "integrity": {
    "sha256": "replace-me"
  }
}
